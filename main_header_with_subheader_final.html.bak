<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Obsession Arc Framework</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg0: #070b13;
  --bg1: #0a0e17;
  --bg2: #111827;
  --bg3: #151d2e;
  --bg4: #1a2540;
  --border: #1e2d4a;
  --border2: #2a3d5e;
  --text1: #e2e8f0;
  --text2: #8892a8;
  --text3: #4a5568;
  --cyan: #22d3ee;
  --cyan-dim: rgba(34,211,238,0.12);
  --cyan-border: rgba(34,211,238,0.25);
  --green: #10b981;
  --green-dim: rgba(16,185,129,0.12);
  --green-border: rgba(16,185,129,0.25);
  --red: #ef4444;
  --red-dim: rgba(239,68,68,0.10);
  --amber: #f59e0b;
  --amber-dim: rgba(245,158,11,0.12);
  --blue: #3b82f6;
  --blue-dim: rgba(59,130,246,0.12);
  --radius: 8px;
  --font: 'JetBrains Mono', monospace;
  --grid-line: rgba(34,211,238,0.025);
}

/* ── LIGHT MODE OVERRIDES ── */
body.light-mode {
  --bg0: #f0f4f8;
  --bg1: #f8fafc;
  --bg2: #ffffff;
  --bg3: #eef2f7;
  --bg4: #e2e8f0;
  --border: #cbd5e1;
  --border2: #94a3b8;
  --text1: #0f172a;
  --text2: #475569;
  --text3: #94a3b8;
  --cyan: #0891b2;
  --cyan-dim: rgba(8,145,178,0.10);
  --cyan-border: rgba(8,145,178,0.25);
  --green: #059669;
  --green-dim: rgba(5,150,105,0.10);
  --green-border: rgba(5,150,105,0.25);
  --red: #dc2626;
  --red-dim: rgba(220,38,38,0.08);
  --amber: #d97706;
  --amber-dim: rgba(217,119,6,0.10);
  --blue: #2563eb;
  --blue-dim: rgba(37,99,235,0.10);
  --grid-line: rgba(8,145,178,0.04);
}

body.light-mode::before {
  background-image:
    linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
}

/* ── THEME TOGGLE SWITCH ── */
.theme-toggle {
  display: flex; align-items: center; gap: 7px;
  cursor: pointer; user-select: none;
}
.theme-toggle-label {
  font-size: 10px; letter-spacing: 1px; text-transform: uppercase;
  color: var(--text3); font-family: var(--font); font-weight: 600;
  transition: color 0.2s;
}
.toggle-track {
  position: relative; width: 36px; height: 20px;
  background: var(--bg4); border: 1px solid var(--border2);
  border-radius: 10px; transition: background 0.25s, border-color 0.25s;
  flex-shrink: 0;
}
.toggle-track.on { background: var(--cyan-dim); border-color: var(--cyan); }
.toggle-thumb {
  position: absolute; top: 2px; left: 2px;
  width: 14px; height: 14px; border-radius: 50%;
  background: var(--text3); transition: transform 0.25s, background 0.25s;
}
.toggle-track.on .toggle-thumb { transform: translateX(16px); background: var(--cyan); }

body {
  font-family: var(--font);
  background: var(--bg1);
  color: var(--text1);
  min-height: 100vh;
  overflow-x: hidden;
}

body::before {
  content: '';
  position: fixed; inset: 0;
  background-image:
    linear-gradient(var(--grid-line) 1px, transparent 1px),
    linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none; z-index: 0;
}

/* ── TOP NAV ── */
.top-nav {
  position: sticky; top: 0; z-index: 200;
  background: var(--bg0);
  border-bottom: 1px solid var(--border);
  display: flex; flex-direction: column;
  align-items: center;
  padding: 0;
}

.top-nav-header {
  display: flex; align-items: center; justify-content: center;
  position: relative; width: 100%;
  padding: 14px 16px 10px;
  gap: 12px;
}

.top-nav-brand {
  font-size: 15px; font-weight: 800; letter-spacing: 5px;
  color: var(--cyan); text-transform: uppercase;
  white-space: nowrap;
}

.top-nav-right {
  position: absolute; right: 16px; top: 50%;
  transform: translateY(-50%);
  display: flex; align-items: center; gap: 10px;
}

.top-nav-tabs {
  display: flex; gap: 0; width: 100%; justify-content: center;
  border-top: 1px solid var(--border);
}

.top-tab {
  padding: 11px 22px;
  font-family: var(--font);
  font-size: 11px; font-weight: 600; letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--text3);
  background: transparent;
  border: none; border-bottom: 2px solid transparent;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
}

.top-tab:hover { color: var(--text2); border-bottom-color: var(--border2); }
.top-tab.active { color: var(--cyan); border-bottom-color: var(--cyan); }

.live-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--green);
  animation: blink 1.5s ease-in-out infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.25} }

.clock-chip {
  font-size: 12px; font-weight: 600;
  color: var(--text2); letter-spacing: 0.5px;
  font-variant-numeric: tabular-nums;
}

/* ── APP SHELL ── */
.app-view { display: none; }
.app-view.active { display: block; }

/* ── SHARED ── */
.container {
  max-width: 900px; margin: 0 auto;
  padding: 28px 20px 80px;
  position: relative; z-index: 1;
}

.section-tag {
  display: inline-block; font-size: 10px; letter-spacing: 3px;
  text-transform: uppercase; color: var(--cyan);
  background: var(--cyan-dim); padding: 3px 12px;
  border-radius: 2px; margin-bottom: 14px;
  border: 1px solid var(--cyan-border);
}

.card {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: var(--radius);
}

.card-inner {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px 14px;
}

.divider { height: 1px; background: var(--border); margin: 14px 0; }

.label {
  font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
  color: var(--text3); margin-bottom: 5px;
}

.val-xl { font-size: 38px; font-weight: 700; font-variant-numeric: tabular-nums; letter-spacing: -0.02em; }
.val-lg { font-size: 22px; font-weight: 700; }
.val-md { font-size: 15px; font-weight: 600; }

.badge {
  display: inline-flex; align-items: center;
  font-size: 10px; font-weight: 700; letter-spacing: 1px;
  text-transform: uppercase; padding: 3px 9px; border-radius: 3px;
}
.badge-green { background: var(--green-dim); color: var(--green); border: 1px solid var(--green-border); }
.badge-cyan  { background: var(--cyan-dim);  color: var(--cyan);  border: 1px solid var(--cyan-border);  }
.badge-amber { background: var(--amber-dim); color: var(--amber); border: 1px solid rgba(245,158,11,0.3); }
.badge-red   { background: var(--red-dim);   color: var(--red);   border: 1px solid rgba(239,68,68,0.25); }
.badge-gray  { background: rgba(255,255,255,0.04); color: var(--text2); border: 1px solid var(--border2); }

.pbar { height: 4px; background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden; }
.pbar-fill { height: 100%; border-radius: 2px; transition: width 0.8s, background 0.4s; }
.pbar-lg { height: 8px; }


.oa-logo-sm{
  width:64px !important;
  height:64px !important;
  margin:0 auto 10px auto !important;
  display:block !important;
  object-fit:contain !important;
}
.oa-logo-md { height:28px; width:28px; object-fit:contain; vertical-align:middle; margin-right:8px; filter:brightness(1.1); }

/* ─────────────────────────────────────────
   H1 DASHBOARD STYLES
───────────────────────────────────────── */
.h1-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
@media (max-width: 600px) { .h1-grid-2 { grid-template-columns: 1fr; } }

.h1-card { background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; }
.h1-stats-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }
.h1-stat { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 10px; text-align: center; }

.h1-tabs { display: flex; background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 3px; gap: 3px; margin-bottom: 14px; }
.h1-tab { flex: 1; padding: 7px 4px; font-family: var(--font); font-size: 10px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; border: none; border-radius: 5px; background: transparent; color: var(--text3); cursor: pointer; transition: all 0.15s; }
.h1-tab.active { background: var(--bg4); color: var(--cyan); }
.h1-tab-panel { display: none; }
.h1-tab-panel.active { display: block; }

.hour-row { display: flex; align-items: center; justify-content: space-between; padding: 7px 6px; border-bottom: 1px solid rgba(30,45,74,0.6); border-radius: 4px; transition: background 0.15s; }
.hour-row:last-child { border-bottom: none; }
.hour-row.active-row { background: var(--cyan-dim); border-radius: var(--radius); border-bottom: none; padding: 7px 10px; }
.win-bar-wrap { width: 56px; height: 3px; background: rgba(255,255,255,0.07); border-radius: 2px; overflow: hidden; display: inline-block; }
.win-bar { height: 100%; border-radius: 2px; }

.dow-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 6px; }
.dow-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 8px 4px; text-align: center; }
.dow-card.today { border-color: var(--cyan); background: var(--cyan-dim); }

.tstop-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 6px; }
.tstop-pill { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 10px 4px; text-align: center; }
.tstop-pill.is-warn { border-color: var(--amber); background: var(--amber-dim); }
.tstop-pill.is-danger { border-color: var(--red); background: var(--red-dim); }

.alert-box { border-radius: var(--radius); padding: 12px 14px; border-left: 3px solid; margin-bottom: 8px; font-size: 12px; line-height: 1.6; }
.alert-box:last-child { margin-bottom: 0; }
.alert-fire   { background: var(--green-dim); border-color: var(--green); }
.alert-info   { background: var(--cyan-dim);  border-color: var(--cyan); }
.alert-warn   { background: var(--amber-dim); border-color: var(--amber); }
.alert-avoid  { background: var(--red-dim);   border-color: var(--red); }
.alert-neutral{ background: var(--bg2);       border-color: var(--border2); }
.alert-title  { font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 3px; }

.calc-row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
.calc-row input, .calc-row select {
  padding: 8px 12px; border: 1px solid var(--border2);
  border-radius: var(--radius); background: var(--bg2); color: var(--text1);
  font-family: var(--font); font-size: 13px;
}
.calc-row input { width: 140px; }
.stop-row { display: flex; justify-content: space-between; align-items: center; padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 12px; }
.stop-row:last-child { border-bottom: none; }

.retrace-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }

.notif-dot { background: var(--red); color: #fff; border-radius: 20px; font-size: 10px; font-weight: 700; padding: 1px 6px; }

/* ─────────────────────────────────────────
   RTH DECISION ENGINE STYLES
───────────────────────────────────────── */
.rth-header { text-align: center; margin-bottom: 36px; }
.rth-header h2 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
.rth-header h2 span { color: var(--cyan); }
.rth-header p { font-size: 12px; color: var(--text2); font-weight: 300; }

.steps-bar { display: flex; justify-content: center; gap: 8px; margin-bottom: 36px; align-items: center; }
.step-dot { width: 32px; height: 4px; border-radius: 2px; background: var(--border); transition: all 0.4s ease; }
.step-dot.active   { background: var(--cyan); box-shadow: 0 0 12px rgba(34,211,238,0.35); }
.step-dot.complete { background: var(--green); }

.rth-panel { display: none; animation: fadeUp 0.35s ease; }
.rth-panel.active { display: block; }
@keyframes fadeUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:none} }

.panel-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--text3); margin-bottom: 8px; }
.panel-question { font-size: 17px; font-weight: 500; color: var(--text1); margin-bottom: 24px; }

.options-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 14px; max-width: 750px; margin: 0 auto; }

.option-btn {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 22px 18px;
  cursor: pointer; text-align: left; position: relative; overflow: hidden;
  transition: all 0.2s ease;
}
.option-btn::before {
  content: ''; position: absolute; top: 0; left: 0;
  width: 100%; height: 3px; background: var(--cyan); opacity: 0; transition: opacity 0.2s;
}
.option-btn:hover { background: var(--bg4); border-color: var(--cyan); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.4); }
.option-btn:hover::before { opacity: 1; }
.opt-icon { font-size: 22px; margin-bottom: 10px; display: block; }
.opt-label { font-size: 14px; font-weight: 600; color: var(--text1); margin-bottom: 5px; }
.opt-desc  { font-size: 11px; color: var(--text2); font-weight: 300; line-height: 1.5; }

.results-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 10px; }
.breadcrumb { display: flex; gap: 6px; align-items: center; font-size: 11px; color: var(--text2); flex-wrap: wrap; }
.bc-item { background: var(--bg3); border: 1px solid var(--border); padding: 4px 10px; border-radius: 4px; }
.bc-arrow { color: var(--text3); }
.reset-btn {
  font-family: var(--font); font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--text2); background: transparent; border: 1px solid var(--border);
  padding: 6px 14px; border-radius: 4px; cursor: pointer; transition: all 0.2s;
}
.reset-btn:hover { color: var(--cyan); border-color: var(--cyan); }

.sequences-list { display: flex; flex-direction: column; gap: 10px; }
.seq-card {
  background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius);
  padding: 18px 20px; display: grid; grid-template-columns: 1fr auto; gap: 14px;
  align-items: center; position: relative; overflow: hidden;
  transition: all 0.2s ease;
}
.seq-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; }
.seq-card.tier-a::before { background: var(--green); }
.seq-card.tier-b::before { background: var(--cyan); }
.seq-card.tier-c::before { background: var(--red); }
.seq-card:hover { background: var(--bg4); transform: translateX(3px); }

.seq-name { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
.seq-description { font-size: 11px; color: var(--text2); font-weight: 300; line-height: 1.5; }
.seq-bar-wrap { margin-top: 8px; height: 3px; background: rgba(255,255,255,0.05); border-radius: 2px; overflow: hidden; }
.seq-bar { height: 100%; border-radius: 2px; transition: width 0.6s ease; }
.tier-a .seq-bar { background: var(--green); }
.tier-b .seq-bar { background: var(--cyan); }
.tier-c .seq-bar { background: var(--red); }

.seq-stats { text-align: right; white-space: nowrap; }
.seq-rate { font-size: 28px; font-weight: 700; line-height: 1; margin-bottom: 4px; }
.tier-a .seq-rate { color: var(--green); }
.tier-b .seq-rate { color: var(--cyan); }
.tier-c .seq-rate { color: var(--red); }
.seq-counts { font-size: 10px; color: var(--text3); letter-spacing: 0.5px; }

.insight-box {
  background: var(--cyan-dim); border: 1px solid var(--cyan-border);
  border-radius: var(--radius); padding: 18px 22px; margin-top: 22px;
}
.insight-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--cyan); margin-bottom: 8px; }
.insight-box p { font-size: 12px; color: var(--text1); line-height: 1.7; font-weight: 300; }

.rth-legend { display: flex; gap: 18px; margin-top: 28px; justify-content: center; flex-wrap: wrap; }
.legend-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--text2); }
.legend-dot { width: 8px; height: 8px; border-radius: 2px; }
.legend-dot.a { background: var(--green); }
.legend-dot.b { background: var(--cyan); }
.legend-dot.c { background: var(--red); }

.pd-badge {
  display: inline-block; margin-top: 12px; font-size: 11px; font-weight: 600; letter-spacing: 0.5px;
  color: var(--green); background: var(--green-dim); border: 1px solid var(--green-border);
  padding: 7px 16px; border-radius: 4px; line-height: 1.4;
}

@media (max-width: 600px) {
  .seq-card { grid-template-columns: 1fr; }
  .seq-stats { text-align: left; }
  .options-grid { grid-template-columns: 1fr; }
  .rth-header h2 { font-size: 18px; }
  .top-tab { padding: 12px 10px; font-size: 10px; }
  .tstop-grid { grid-template-columns: repeat(2,1fr); }
}

/* ─────────────────────────────────────────
   RISK CALCULATOR STYLES
───────────────────────────────────────── */
.risk-header { text-align: center; margin-bottom: 28px; }
.risk-header h2 { font-size: 22px; font-weight: 700; margin-bottom: 6px; }
.risk-header h2 span { color: var(--cyan); }
.risk-header p { font-size: 12px; color: var(--text2); font-weight: 300; }

.risk-instrument-grid {
  display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; margin-bottom: 20px;
}
@media (max-width:700px) { .risk-instrument-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width:400px) { .risk-instrument-grid { grid-template-columns: 1fr 1fr; } }

.inst-btn {
  background: var(--bg3); border: 2px solid var(--border);
  border-radius: var(--radius); padding: 12px 8px; text-align: center;
  cursor: pointer; transition: all 0.15s; font-family: var(--font);
}
.inst-btn:hover { border-color: var(--cyan); background: var(--bg4); }
.inst-btn.selected { border-color: var(--cyan); background: var(--cyan-dim); }
.inst-btn .inst-ticker { font-size: 14px; font-weight: 700; color: var(--text1); }
.inst-btn .inst-name { font-size: 9px; color: var(--text3); letter-spacing: 0.5px; margin-top: 2px; }
.inst-btn .inst-mult { font-size: 10px; color: var(--cyan); margin-top: 4px; font-weight: 600; }

.risk-input-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px;
}
@media (max-width: 600px) { .risk-input-grid { grid-template-columns: 1fr; } }

.risk-field { display: flex; flex-direction: column; gap: 5px; }
.risk-field label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--text3); }
.risk-field input, .risk-field select {
  padding: 10px 12px;
  border: 1px solid var(--border2);
  border-radius: var(--radius);
  background: var(--bg2); color: var(--text1);
  font-family: var(--font); font-size: 13px;
  width: 100%;
  outline: none; transition: border-color 0.15s;
}
.risk-field input:focus, .risk-field select:focus { border-color: var(--cyan); }
.risk-field .field-hint { font-size: 10px; color: var(--text3); margin-top: 2px; }

.risk-results-grid {
  display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; margin-bottom: 14px;
}
@media (max-width:600px) { .risk-results-grid { grid-template-columns: repeat(2,1fr); } }

.risk-result-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 14px 12px; text-align: center;
}
.risk-result-card.highlight { border-color: var(--cyan); background: var(--cyan-dim); }
.risk-result-card.danger   { border-color: var(--red);  background: var(--red-dim); }
.risk-result-card.success  { border-color: var(--green);background: var(--green-dim); }
.risk-result-label { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--text3); margin-bottom: 6px; }
.risk-result-val { font-size: 20px; font-weight: 700; color: var(--text1); font-variant-numeric: tabular-nums; }
.risk-result-sub { font-size: 10px; color: var(--text3); margin-top: 3px; }

.risk-breakdown-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 8px 0; border-bottom: 1px solid var(--border);
  font-size: 12px;
}
.risk-breakdown-row:last-child { border-bottom: none; }
.risk-breakdown-row .rb-label { color: var(--text2); }
.risk-breakdown-row .rb-val { font-weight: 700; font-variant-numeric: tabular-nums; }

.rr-bar-wrap { height: 10px; background: rgba(255,255,255,0.06); border-radius: 5px; overflow: hidden; margin-top: 6px; }
.rr-bar-fill { height: 100%; border-radius: 5px; transition: width 0.6s, background 0.3s; }

.contract-spec-table { width: 100%; border-collapse: collapse; font-size: 11px; }
.contract-spec-table th {
  text-align: left; padding: 7px 10px;
  background: var(--bg2); color: var(--text3); letter-spacing: 1px; font-size: 9px; text-transform: uppercase;
  border-bottom: 1px solid var(--border);
}
.contract-spec-table td { padding: 8px 10px; border-bottom: 1px solid rgba(30,45,74,0.5); }
.contract-spec-table tr:last-child td { border-bottom: none; }
.contract-spec-table tr:hover td { background: var(--bg4); }
.spec-ticker { font-weight: 700; color: var(--cyan); }
.spec-mini { color: var(--amber); font-size: 10px; }

.risk-tab-bar { display:flex; background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 3px; gap: 3px; margin-bottom: 18px; }
.risk-tab { flex:1; padding: 8px 4px; font-family: var(--font); font-size: 10px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; border: none; border-radius: 5px; background: transparent; color: var(--text3); cursor: pointer; transition: all 0.15s; }
.risk-tab.active { background: var(--bg4); color: var(--cyan); }
.risk-tab-panel { display: none; }
.risk-tab-panel.active { display: block; }

.position-size-output {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 18px; margin-top: 14px;
}
.pso-main { font-size: 42px; font-weight: 700; color: var(--cyan); font-variant-numeric: tabular-nums; text-align: center; margin: 8px 0; }
.pso-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--text3); text-align: center; }

.warn-box { background: var(--amber-dim); border: 1px solid rgba(245,158,11,0.35); border-radius: var(--radius); padding: 10px 14px; font-size: 11px; color: var(--amber); margin-top: 10px; line-height: 1.6; }
.info-box  { background: var(--cyan-dim);  border: 1px solid var(--cyan-border);         border-radius: var(--radius); padding: 10px 14px; font-size: 11px; color: var(--text2);  margin-top: 10px; line-height: 1.6; }

/* ─────────────────────────────────────────
   QUICK VIEW TABLE
───────────────────────────────────────── */
.qv-table-head th {
  padding: 7px 10px; background: var(--bg2);
  color: var(--text3); font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase;
  border-bottom: 1px solid var(--border); text-align: right; white-space: nowrap;
}
.qv-table-head th:first-child { text-align: left; }
.qv-row td {
  padding: 7px 10px; border-bottom: 1px solid rgba(30,45,74,0.4);
  text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap;
}
.qv-row td:first-child { text-align: left; font-weight: 700; color: var(--text2); }
.qv-row:last-child td { border-bottom: none; }
.qv-row:hover td { background: var(--bg4); }
.qv-row.qv-highlight td { background: var(--cyan-dim); }
.qv-row.qv-highlight td:first-child { color: var(--cyan); }
.qv-cell-pos { color: var(--green); font-weight: 600; }
.qv-cell-neg { color: var(--red);   font-weight: 600; }
.qv-cell-big { color: var(--cyan);  font-weight: 700; }
.qv-inst-strip {
  display: flex; gap: 10px; flex-wrap: wrap;
}
.qv-spec-chip {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 8px 14px; font-size: 11px;
  display: flex; flex-direction: column; gap: 2px;
}
.qv-spec-chip .qsc-label { font-size: 9px; color: var(--text3); letter-spacing: 1.5px; text-transform: uppercase; }
.qv-spec-chip .qsc-val   { font-size: 13px; font-weight: 700; }


/* HEADER REDESIGN OVERRIDE */
.top-nav{
  position: sticky;
  top:0;
  background:#030814 !important;
  border-bottom:1px solid #0f2740 !important;
}
.top-nav-header{
  flex-direction:column !important;
  justify-content:center !important;
  gap:10px !important;
  padding:18px 16px 16px !important;
}
.top-nav-brand{
  font-size:24px !important;
  font-weight:800 !important;
  letter-spacing:7px !important;
  color:#22d3ee !important;
}
.top-nav-right{
  position:static !important;
  transform:none !important;
  margin-top:8px !important;
}
.oa-logo-sm{
  width:38px !important;
  height:38px !important;
  margin:0 auto 6px auto !important;
  display:block !important;
}


.oa-subheader{
  font-size:11px;
  letter-spacing:4px;
  text-transform:uppercase;
  color:#64748b;
  text-align:center;
  margin-top:4px;
  margin-bottom:8px;
}

</style>
</head>
<body>

<!-- TOP NAV -->
<nav class="top-nav">
  <!-- Row 1: Logo + Title (centered), clocks (right) -->
  <div class="top-nav-header">
    <div style="display:flex;align-items:center;gap:12px;">
      <img src="data:image/png;base64," alt="OA" style="height:36px;width:36px;object-fit:contain;filter:brightness(1.15) drop-shadow(0 0 6px rgba(0,212,255,0.35));mix-blend-mode:screen;">
      <span class="top-nav-brand">Obsession Arc</span>
    </div>
    <div class="top-nav-right">
      <span class="live-dot"></span>
      <div style="display:flex;align-items:center;gap:12px;">
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:1px;">
          <span style="font-size:9px;letter-spacing:1.5px;color:var(--text3);text-transform:uppercase;">NY</span>
          <span class="clock-chip" id="top-clock">--:--:--</span>
        </div>
        <div style="width:1px;height:28px;background:var(--border);"></div>
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:1px;">
          <span style="font-size:9px;letter-spacing:1.5px;color:var(--text3);text-transform:uppercase;">IST</span>
          <span class="clock-chip" id="top-clock-ist">--:--:--</span>
        </div>
      </div>
      <span id="top-alert-dot" class="notif-dot" style="display:none;"></span>
      <!-- Theme Toggle -->
      <div class="theme-toggle" onclick="toggleTheme()" title="Toggle light/dark mode">
        <span class="theme-toggle-label" id="theme-label">DARK</span>
        <div class="toggle-track" id="toggle-track">
          <div class="toggle-thumb"></div>
        </div>
      </div>
    </div>
  </div>
  <!-- Row 2: Tabs centered -->
  <div class="top-nav-tabs">
    <button class="top-tab active" id="topTab-rth" onclick="switchApp('rth')">RTH Decision Engine</button>
    <button class="top-tab" id="topTab-h1" onclick="switchApp('h1')">H1 Pattern</button>
    <button class="top-tab" id="topTab-risk" onclick="switchApp('risk')">Risk Management</button>
    <button class="top-tab" id="topTab-sdrange" onclick="switchApp('sdrange')">SDRange+ Framework</button>
  </div>
</nav>

<!-- ══════════════════════════════════════
     VIEW 1: H1 PATTERN DASHBOARD
══════════════════════════════════════ -->
<div class="app-view" id="view-h1">

  <!-- Inner bottom nav for H1 sections -->
  <div style="position:sticky;top:49px;z-index:150;background:var(--bg0);border-bottom:1px solid var(--border);display:flex;">
    <button class="h1-tab active" id="h1nav-live"   onclick="showH1('live')"  style="flex:1;border-radius:0;padding:11px 4px;font-size:10px;border:none;background:transparent;font-family:var(--font);letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all 0.15s;border-bottom:2px solid transparent;" id="h1nav-live">📡 Live</button>
    <button class="h1-tab"        id="h1nav-hours"  onclick="showH1('hours')" style="flex:1;border-radius:0;padding:11px 4px;font-size:10px;border:none;background:transparent;font-family:var(--font);letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all 0.15s;border-bottom:2px solid transparent;">🕐 Hours</button>
    <button class="h1-tab"        id="h1nav-stops"  onclick="showH1('stops')" style="flex:1;border-radius:0;padding:11px 4px;font-size:10px;border:none;background:transparent;font-family:var(--font);letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all 0.15s;border-bottom:2px solid transparent;">🛡 Stops</button>
    <button class="h1-tab"        id="h1nav-dol"    onclick="showH1('dol')"   style="flex:1;border-radius:0;padding:11px 4px;font-size:10px;border:none;background:transparent;font-family:var(--font);letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all 0.15s;border-bottom:2px solid transparent;">⏱ DOL</button>
  </div>

  <div class="container" style="max-width:860px;">

    <!-- LIVE PAGE -->
    <div class="h1-tab-panel active" id="h1p-live">

      <div style="text-align:center;padding:18px 0 6px;">
        <div class="section-tag"><img class="oa-logo-sm" src="data:image/png;base64," alt="OA">Obsession Arc Framework · H1 Pattern</div>
        <div style="font-size:11px;color:var(--text3);margin-top:4px;letter-spacing:0.5px;">Live Trade Window Monitor · NQ Futures</div>
      </div>

      <div class="h1-grid-2" style="margin-bottom:14px;">
        <!-- Clock card -->
        <div class="h1-card">
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:12px;">
            <span class="live-dot"></span>
            <span class="label" style="margin:0;">Live Clock</span>
          </div>
          <!-- NY + IST side by side -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;">
            <div style="background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px;">
              <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
                <span style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--cyan);font-weight:700;">🇺🇸 New York</span>
              </div>
              <div class="val-xl" id="h1-clock" style="font-size:28px;">--:--:--</div>
              <div style="font-size:10px;color:var(--text3);margin-top:3px;letter-spacing:0.5px;">EST / EDT</div>
            </div>
            <div style="background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px;">
              <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
                <span style="font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--amber);font-weight:700;">🇮🇳 India</span>
              </div>
              <div class="val-xl" id="h1-clock-ist" style="font-size:28px;color:var(--amber);">--:--:--</div>
              <div style="font-size:10px;color:var(--text3);margin-top:3px;letter-spacing:0.5px;">IST (UTC+5:30)</div>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:4px;">
            <div><div class="label">Trigger hour</div><div class="val-md" id="h1-trigger">--:00</div></div>
            <div><div class="label">Trade window</div><div class="val-md" id="h1-window">--:--</div></div>
          </div>
          <div style="margin-top:12px;">
            <div class="label">Hour progress</div>
            <div style="display:flex;align-items:center;gap:8px;margin-top:4px;">
              <div class="pbar" style="flex:1;"><div class="pbar-fill" id="h1-hrprog" style="background:var(--green);width:0%;"></div></div>
              <span style="font-size:11px;color:var(--text3);" id="h1-minsleft">60m</span>
            </div>
          </div>
        </div>

        <!-- Status card -->
        <div class="h1-card">
          <div class="label">Current trade window</div>
          <div style="margin:6px 0;" id="h1-cbadge"></div>
          <div class="val-lg" id="h1-cwr" style="margin-bottom:6px;">--%</div>
          <div style="font-size:12px;color:var(--text2);line-height:1.7;" id="h1-cdetail"></div>
          <div class="divider"></div>
          <div class="label">Elapsed this hour</div>
          <div style="display:flex;align-items:center;justify-content:space-between;margin-top:4px;">
            <div class="val-md" id="h1-elapsed">0:00</div>
            <div id="h1-action-badge"></div>
          </div>
          <div class="pbar" style="margin-top:6px;"><div class="pbar-fill" id="h1-minprog" style="width:0%;"></div></div>
          <div style="margin-top:10px;">
            <div class="label">DOL probability</div>
            <div style="display:flex;align-items:center;gap:8px;margin-top:4px;">
              <div class="pbar pbar-lg" style="flex:1;"><div class="pbar-fill" id="h1-dolbar" style="width:0%;"></div></div>
              <span style="font-size:13px;font-weight:700;min-width:40px;text-align:right;" id="h1-dolval">--%</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Alerts -->
      <div class="h1-card" style="margin-bottom:14px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
          <div class="section-tag" style="margin:0;">Live Alerts</div>
          <span style="font-size:11px;color:var(--text3);" id="h1-alertcount"></span>
        </div>
        <div id="h1-alerts"></div>
      </div>

      <!-- Time stops -->
      <div class="h1-card" style="margin-bottom:14px;">
        <div class="label" style="margin-bottom:10px;">Time-based exit rules</div>
        <div class="tstop-grid" id="h1-tstops">
          <div class="tstop-pill"><div style="font-size:14px;font-weight:700;">:10</div><div style="font-size:10px;color:var(--text3);margin-top:2px;">45% left</div><div style="font-size:10px;color:var(--amber);margin-top:3px;">Consider scratch</div></div>
          <div class="tstop-pill"><div style="font-size:14px;font-weight:700;">:15</div><div style="font-size:10px;color:var(--text3);margin-top:2px;">39% left</div><div style="font-size:10px;color:var(--red);margin-top:3px;">Strong exit</div></div>
          <div class="tstop-pill"><div style="font-size:14px;font-weight:700;">:30</div><div style="font-size:10px;color:var(--text3);margin-top:2px;">23% left</div><div style="font-size:10px;color:var(--red);margin-top:3px;">Should be out</div></div>
          <div class="tstop-pill"><div style="font-size:14px;font-weight:700;">:45</div><div style="font-size:10px;color:var(--text3);margin-top:2px;">10% left</div><div style="font-size:10px;color:var(--red);margin-top:3px;">Dead trade</div></div>
        </div>
      </div>

      <!-- DOW -->
      <div class="h1-card" style="margin-bottom:14px;">
        <div class="label" style="margin-bottom:10px;">Day of week</div>
        <div class="dow-grid" id="h1-dow"></div>
      </div>

      <!-- Summary -->
      <div class="h1-card">
        <div class="label" style="margin-bottom:10px;">5-Year summary (Dec 2020 – Dec 2025)</div>
        <div class="h1-stats-grid">
          <div class="h1-stat"><div class="label">Trades</div><div class="val-md">26,706</div></div>
          <div class="h1-stat"><div class="label">Cont. WR</div><div class="val-md" style="color:var(--green);">73.0%</div></div>
          <div class="h1-stat"><div class="label">Rev. WR</div><div class="val-md" style="color:var(--amber);">61.8%</div></div>
          <div class="h1-stat"><div class="label">Avg DOL</div><div class="val-md">:09</div></div>
          <div class="h1-stat"><div class="label">Med. Adverse</div><div class="val-md">4.2 pts</div></div>
          <div class="h1-stat"><div class="label">Sundays</div><div class="val-md">Excluded</div></div>
        </div>
      </div>
    </div>

    <!-- HOURS PAGE -->
    <div class="h1-tab-panel" id="h1p-hours">
      <div style="text-align:center;padding:18px 0 6px;">
        <div class="section-tag"><img class="oa-logo-sm" src="data:image/png;base64," alt="OA">Obsession Arc Framework · H1 Pattern</div>
        <div style="font-size:11px;color:var(--text3);margin-top:4px;letter-spacing:0.5px;">Hourly Win Rate Analysis · NQ Futures</div>
      </div>
      <div class="h1-card">
        <div class="label" style="margin-bottom:4px;">Trigger hours — continuation patterns only</div>
        <div style="display:flex;gap:14px;font-size:10px;color:var(--text3);margin-bottom:12px;">
          <span style="color:var(--green);">★ A+ (≥78%)</span>
          <span style="color:var(--amber);">△ Below avg</span>
          <span style="color:var(--red);">✕ Avoid</span>
        </div>
        <div id="h1-hourslist"></div>
      </div>
    </div>

    <!-- STOPS PAGE -->
    <div class="h1-tab-panel" id="h1p-stops">
      <div style="text-align:center;padding:18px 0 6px;">
        <div class="section-tag"><img class="oa-logo-sm" src="data:image/png;base64," alt="OA">Obsession Arc Framework · H1 Pattern</div>
        <div style="font-size:11px;color:var(--text3);margin-top:4px;letter-spacing:0.5px;">Stop Loss & Excursion Data · NQ Futures</div>
      </div>
      <div class="h1-card" style="margin-bottom:14px;">
        <div class="label" style="margin-bottom:10px;">Stop loss guidance</div>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:8px;">
          <div class="tstop-pill"><div style="font-size:16px;font-weight:700;">10 pt</div><div style="font-size:11px;color:var(--text2);margin-top:3px;">catches 74% of winners</div></div>
          <div class="tstop-pill"><div style="font-size:16px;font-weight:700;">15 pt</div><div style="font-size:11px;color:var(--text2);margin-top:3px;">catches 84% of winners</div></div>
          <div class="tstop-pill"><div style="font-size:16px;font-weight:700;">22 pt</div><div style="font-size:11px;color:var(--text2);margin-top:3px;">catches 90% of winners</div></div>
          <div class="tstop-pill"><div style="font-size:16px;font-weight:700;">33 pt</div><div style="font-size:11px;color:var(--text2);margin-top:3px;">catches 95% of winners</div></div>
        </div>

        <div class="divider"></div>
        <div class="label" style="margin-bottom:10px;">Stop loss calculator</div>
        <div class="calc-row">
          <input type="number" id="h1-entry" placeholder="Entry price" oninput="h1CalcStops()">
          <select id="h1-dir" onchange="h1CalcStops()">
            <option value="long">Long</option>
            <option value="short">Short</option>
          </select>
        </div>
        <div id="h1-stopresults" style="margin-top:12px;"></div>

        <div class="divider"></div>
        <div class="label" style="margin-bottom:10px;">Adverse excursion (before DOL hit)</div>
        <div class="h1-stats-grid">
          <div class="h1-stat"><div class="label">Median</div><div class="val-md">4.2 pt</div></div>
          <div class="h1-stat"><div class="label">Mean</div><div class="val-md">8.9 pt</div></div>
          <div class="h1-stat"><div class="label">75th %ile</div><div class="val-md">10.2 pt</div></div>
          <div class="h1-stat"><div class="label">90th %ile</div><div class="val-md">21.8 pt</div></div>
          <div class="h1-stat"><div class="label">95th %ile</div><div class="val-md">32.5 pt</div></div>
        </div>

        <div class="divider"></div>
        <div class="label" style="margin-bottom:10px;">Retracement distribution (winners)</div>
        <div id="h1-retrace"></div>
      </div>
    </div>

    <!-- DOL PAGE -->
    <div class="h1-tab-panel" id="h1p-dol">
      <div style="text-align:center;padding:18px 0 6px;">
        <div class="section-tag"><img class="oa-logo-sm" src="data:image/png;base64," alt="OA">Obsession Arc Framework · H1 Pattern</div>
        <div style="font-size:11px;color:var(--text3);margin-top:4px;letter-spacing:0.5px;">Direction of Liquidity Timing Data · NQ Futures</div>
      </div>
      <div class="h1-card">
        <div class="label" style="margin-bottom:10px;">DOL timing — cumulative %</div>
        <div id="h1-dolcumul"></div>

        <div class="divider"></div>
        <div class="label" style="margin-bottom:6px;">Time-based success rate</div>
        <div style="font-size:11px;color:var(--text3);margin-bottom:10px;">If X minutes pass without DOL hit, probability it eventually fills:</div>
        <div id="h1-timecutoff"></div>

        <div class="divider"></div>
        <div class="label" style="margin-bottom:10px;">TDO position filter</div>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:8px;">
          <div class="h1-stat"><div class="label">Longs above TDO</div><div class="val-md" style="color:var(--green);">74.1%</div></div>
          <div class="h1-stat"><div class="label">Longs below TDO</div><div class="val-md">72.2%</div></div>
          <div class="h1-stat"><div class="label">Shorts above TDO</div><div class="val-md">71.4%</div></div>
          <div class="h1-stat"><div class="label">Shorts below TDO</div><div class="val-md">72.2%</div></div>
        </div>
        <div style="font-size:11px;color:var(--text3);margin-top:10px;line-height:1.6;">Longs above TDO get +2% edge. Shorts are consistent regardless of TDO position.</div>
      </div>
    </div>

  </div><!-- /container -->
</div><!-- /view-h1 -->


<!-- ══════════════════════════════════════
     VIEW 2: RTH DECISION ENGINE
══════════════════════════════════════ -->
<div class="app-view active" id="view-rth">
  <div class="container">

    <div class="rth-header">
      <div class="section-tag"><img class="oa-logo-sm" src="data:image/png;base64," alt="OA">Obsession Arc Framework · NQ Futures</div>
      <h2>PD RTH Range <span>Decision Engine</span></h2>
      <p>IF-THEN sequence logic backed by historical NQ data</p>
      <div class="pd-badge"><img class="oa-logo-sm" src="data:image/png;base64," alt="OA">Obsession Arc Framework · PD RTH Range = Previous Day's Regular Trading Hours (9:30 AM – 4:15 PM ET)</div>
    </div>

    <div class="steps-bar">
      <div class="step-dot active" id="rth-dot1"></div>
      <div class="step-dot"        id="rth-dot2"></div>
      <div class="step-dot"        id="rth-dot3"></div>
    </div>

    <!-- Framework Documentation -->
    <div style="margin-bottom:28px;">
      <button onclick="toggleRthDocs()" id="rth-docs-btn" style="
        width:100%;display:flex;align-items:center;justify-content:space-between;
        background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);
        padding:12px 18px;cursor:pointer;font-family:var(--font);color:var(--text2);
        font-size:11px;letter-spacing:1.5px;text-transform:uppercase;transition:all 0.2s;
      ">
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:14px;">📖</span>
          <span>Framework Guide — PD RTH Range+</span>
        </div>
        <span id="rth-docs-arrow" style="font-size:14px;transition:transform 0.3s;">▼</span>
      </button>

      <div id="rth-docs-panel" style="display:none;margin-top:2px;">

        <!-- Intro -->
        <div class="h1-card" style="margin-bottom:10px;border-top-left-radius:0;border-top-right-radius:0;border-top:none;">
          <div class="label" style="margin-bottom:8px;">Introduction</div>
          <p style="font-size:12px;color:var(--text2);line-height:1.8;">
            The <strong style="color:var(--cyan);">PD RTH Range+</strong> is a framework designed to visualize and track previous day's Regular Trading Hours (RTH) ranges for futures markets. It identifies key price levels established during standard US trading hours <strong>(9:30 AM – 4:15 PM ET)</strong> and Globex hours, helping traders identify important levels and fair value zones.
          </p>
          <p style="font-size:12px;color:var(--text2);line-height:1.8;margin-top:8px;">
            This framework is built around <strong style="color:var(--cyan);">IF-THEN sequence logic</strong> — backed by historical NQ data — to generate your daily directional bias.
          </p>
        </div>

        <!-- Range Modes -->
        <div class="h1-card" style="margin-bottom:10px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
            <span style="font-size:16px;">📊</span>
            <div class="label" style="margin:0;color:var(--cyan);">Range Functions & Plot Modes</div>
          </div>
          <p style="font-size:12px;color:var(--text2);line-height:1.8;">
            The tool operates with two modes: <strong style="color:var(--text1);">"RTH" Range</strong> and <strong style="color:var(--text1);">"Previous Day" Range</strong>. These help you visualize the previous day's points of interest and swing high/low — framing the current day's candle in relation to both the RTH range and the full previous day range.
          </p>
        </div>

        <!-- Projections -->
        <div class="h1-card" style="margin-bottom:10px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
            <span style="font-size:16px;">🎯</span>
            <div class="label" style="margin:0;color:var(--cyan);">Projections Feature</div>
          </div>
          <p style="font-size:12px;color:var(--text2);line-height:1.8;">
            The projection feature has two plot modes: <strong style="color:var(--text1);">"Fixed"</strong> and <strong style="color:var(--text1);">"Custom"</strong>. The Fixed mode uses the <strong style="color:var(--amber);">Rule of Thirds</strong> with two key zones:
          </p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px;">
            <div style="background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:10px 12px;">
              <div style="font-size:13px;font-weight:700;color:var(--green);">0.33 – 0.66</div>
              <div style="font-size:11px;color:var(--text3);margin-top:3px;">First deviation zone. Price often stalls and retraces back into range from here.</div>
            </div>
            <div style="background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:10px 12px;">
              <div style="font-size:13px;font-weight:700;color:var(--red);">1.33 – 1.66</div>
              <div style="font-size:11px;color:var(--text3);margin-top:3px;">Extended deviation zone. Price exhausts above/below range at these levels.</div>
            </div>
          </div>
          <div style="margin-top:10px;padding:10px 12px;background:var(--cyan-dim);border:1px solid var(--cyan-border);border-radius:var(--radius);">
            <div style="font-size:11px;color:var(--cyan);font-weight:600;">⚡ Actionable Areas</div>
            <div style="font-size:11px;color:var(--text2);margin-top:4px;line-height:1.6;">These projection zones are where you expect price to lose momentum and retrace back into the range — your entry triggers for retracements and reversals.</div>
          </div>
        </div>

        <!-- Premium & Discount -->
        <div class="h1-card" style="margin-bottom:10px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
            <span style="font-size:16px;">⚖</span>
            <div class="label" style="margin:0;color:var(--cyan);">Dynamic Premium & Discount</div>
          </div>
          <p style="font-size:12px;color:var(--text2);line-height:1.8;">
            Dynamically identifies fair value and equilibrium at current price — updating until projections or levels are met and a swing high/low has formed.
          </p>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:10px;">
            <div style="background:var(--red-dim);border:1px solid rgba(239,68,68,0.25);border-radius:var(--radius);padding:8px;text-align:center;">
              <div style="font-size:11px;font-weight:700;color:var(--red);">PREMIUM</div>
              <div style="font-size:10px;color:var(--text3);margin-top:2px;">Above EQ</div>
            </div>
            <div style="background:var(--cyan-dim);border:1px solid var(--cyan-border);border-radius:var(--radius);padding:8px;text-align:center;">
              <div style="font-size:11px;font-weight:700;color:var(--cyan);">EQUILIBRIUM</div>
              <div style="font-size:10px;color:var(--text3);margin-top:2px;">Fair Value</div>
            </div>
            <div style="background:var(--green-dim);border:1px solid var(--green-border);border-radius:var(--radius);padding:8px;text-align:center;">
              <div style="font-size:11px;font-weight:700;color:var(--green);">DISCOUNT</div>
              <div style="font-size:10px;color:var(--text3);margin-top:2px;">Below EQ</div>
            </div>
          </div>
        </div>

        <!-- Trading Sequences -->
        <div class="h1-card" style="margin-bottom:10px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
            <span style="font-size:16px;">🔁</span>
            <div class="label" style="margin:0;color:var(--cyan);">Trading Range Sequences</div>
          </div>
          <p style="font-size:12px;color:var(--text2);line-height:1.8;margin-bottom:12px;">
            The framework generates your daily bias by following IF-THEN sequences. These are data-backed by statistics and form the core logic of the Decision Engine above.
          </p>
          <div style="display:flex;flex-direction:column;gap:6px;">
            <div style="background:var(--bg2);border:1px solid var(--green-border);border-radius:var(--radius);padding:9px 12px;display:flex;align-items:center;gap:10px;">
              <span style="font-size:11px;font-weight:700;color:var(--green);min-width:60px;">EQ → High</span>
              <span style="font-size:10px;color:var(--text3);">EQ hit first → High is next probable target (~52–57%)</span>
            </div>
            <div style="background:var(--bg2);border:1px solid var(--green-border);border-radius:var(--radius);padding:9px 12px;display:flex;align-items:center;gap:10px;">
              <span style="font-size:11px;font-weight:700;color:var(--green);min-width:60px;">EQ → Low</span>
              <span style="font-size:10px;color:var(--text3);">EQ hit first → Low is next probable target (~75%)</span>
            </div>
            <div style="background:var(--bg2);border:1px solid var(--cyan-border);border-radius:var(--radius);padding:9px 12px;display:flex;align-items:center;gap:10px;">
              <span style="font-size:11px;font-weight:700;color:var(--cyan);min-width:60px;">High → EQ</span>
              <span style="font-size:10px;color:var(--text3);">PD High tagged → EQ is next target (~89–91%). Strongest mean reversion setup.</span>
            </div>
            <div style="background:var(--bg2);border:1px solid var(--cyan-border);border-radius:var(--radius);padding:9px 12px;display:flex;align-items:center;gap:10px;">
              <span style="font-size:11px;font-weight:700;color:var(--cyan);min-width:60px;">Low → EQ</span>
              <span style="font-size:10px;color:var(--text3);">PD Low tagged → EQ is next target (~89–94%). Highest edge in the dataset.</span>
            </div>
            <div style="background:var(--bg2);border:1px solid var(--amber-dim);border-radius:var(--radius);padding:9px 12px;display:flex;align-items:center;gap:10px;">
              <span style="font-size:11px;font-weight:700;color:var(--amber);min-width:60px;">→ Projection</span>
              <span style="font-size:10px;color:var(--text3);">EQ → Fixed Projections (0.33–0.66 / 1.33–1.66) or Projections → EQ reversal</span>
            </div>
          </div>
        </div>

        <!-- Retracements & Reversals -->
        <div class="h1-card" style="margin-bottom:10px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
            <span style="font-size:16px;">↩</span>
            <div class="label" style="margin:0;color:var(--cyan);">Retracements vs Reversals</div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <div style="background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:12px;">
              <div style="font-size:11px;font-weight:700;color:var(--green);margin-bottom:6px;">📉 RETRACEMENTS</div>
              <div style="font-size:11px;color:var(--text2);line-height:1.6;">Taken from projection zones back to <strong>Equilibrium</strong>. Participate in the move to fair value from the deviation of the range.</div>
            </div>
            <div style="background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:12px;">
              <div style="font-size:11px;font-weight:700;color:var(--red);margin-bottom:6px;">🔄 REVERSALS</div>
              <div style="font-size:11px;color:var(--text2);line-height:1.6;">Taken from projection zones all the way to opposing range levels — <strong>EQ or High/Low</strong>.</div>
            </div>
          </div>
        </div>

        <!-- ETH Note -->
        <div class="h1-card">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
            <span style="font-size:16px;">🕯</span>
            <div class="label" style="margin:0;color:var(--cyan);">ETH Candle Transparency</div>
          </div>
          <p style="font-size:12px;color:var(--text2);line-height:1.8;">
            Electronic Trading Hours (ETH) candles outside of <strong>9:30 AM – 4:15 PM ET</strong> are displayed with reduced opacity on the indicator, helping you focus on RTH price action — which is the core basis for the framework's trading day.
          </p>
          <div style="margin-top:8px;font-size:11px;color:var(--text3);display:flex;gap:16px;flex-wrap:wrap;">
            <span style="color:var(--red);">◼ 4:15 PM — RTH Close</span>
            <span style="color:var(--green);">◼ 9:30 AM — RTH Open</span>
            <span>Outside these = ETH (lower opacity)</span>
          </div>
        </div>

      </div>
    </div>

    <!-- Step 1 -->
    <div class="rth-panel active" id="rth-panel1">
      <div class="panel-label">Step 1 of 2</div>
      <div class="panel-question">Which PD RTH level was hit first today?</div>
      <p style="font-size:12px;color:var(--text2);margin-bottom:20px;text-align:center;">Select one of the following:</p>
      <div class="options-grid">
        <div class="option-btn" onclick="rthSelectLevel('EQ')">
          <span class="opt-icon">⚖</span>
          <div class="opt-label">Equilibrium (EQ)</div>
          <div class="opt-desc">Price touched the midpoint of previous day's RTH range first</div>
        </div>
        <div class="option-btn" onclick="rthSelectLevel('High')">
          <span class="opt-icon">▲</span>
          <div class="opt-label">PD RTH High</div>
          <div class="opt-desc">Price touched the previous day's RTH high first</div>
        </div>
        <div class="option-btn" onclick="rthSelectLevel('Low')">
          <span class="opt-icon">▼</span>
          <div class="opt-label">PD RTH Low</div>
          <div class="opt-desc">Price touched the previous day's RTH low first</div>
        </div>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="rth-panel" id="rth-panel2">
      <div class="panel-label">Step 2 of 2</div>
      <div class="panel-question">During which session was it hit?</div>
      <p style="font-size:12px;color:var(--text2);margin-bottom:20px;text-align:center;">Select one of the following:</p>
      <div class="options-grid">
        <div class="option-btn" onclick="rthSelectSession('asia')">
          <span class="opt-icon">🌏</span>
          <div class="opt-label">Asia Session</div>
          <div class="opt-desc">Globex overnight / Asia hours</div>
        </div>
        <div class="option-btn" onclick="rthSelectSession('london')">
          <span class="opt-icon">🌍</span>
          <div class="opt-label">London Session</div>
          <div class="opt-desc">European / London open hours</div>
        </div>
        <div class="option-btn" onclick="rthSelectSession('any')">
          <span class="opt-icon">◎</span>
          <div class="opt-label">Core (No Session Filter)</div>
          <div class="opt-desc">Core sequences without session filter</div>
        </div>
      </div>
    </div>

    <!-- Step 3: Results -->
    <div class="rth-panel" id="rth-panel3">
      <div class="results-header">
        <div class="breadcrumb" id="rth-bc"></div>
        <button class="reset-btn" onclick="rthReset()">↺ Reset</button>
      </div>
      <div class="sequences-list" id="rth-seqlist"></div>
      <div class="insight-box" id="rth-insight">
        <div class="insight-label">▸ Key Insight</div>
        <p id="rth-insighttext"></p>
      </div>
      <div class="rth-legend">
        <div class="legend-item"><div class="legend-dot a"></div>A-Tier: 85%+</div>
        <div class="legend-item"><div class="legend-dot b"></div>B-Tier: 70–84%</div>
        <div class="legend-item"><div class="legend-dot c"></div>C-Tier: &lt;70%</div>
      </div>
    </div>

  </div>
</div><!-- /view-rth -->


<!-- ══════════════════════════════════════
     VIEW 3: RISK MANAGEMENT CALCULATOR
══════════════════════════════════════ -->
<div class="app-view" id="view-risk">
  <div class="container" style="max-width:900px;">

    <div class="risk-header">
      <div class="section-tag"><img class="oa-logo-sm" src="data:image/png;base64," alt="OA">Obsession Arc Framework · Risk Management</div>
      <h2>Contract Size & <span>Risk Calculator</span></h2>
      <p>Position sizing, dollar risk, P&L, and contract specs for NQ, MNQ, ES, MES, YM, GC, MGC & 6E</p>
    </div>

    <!-- Sub-tab bar -->
    <div class="risk-tab-bar">
      <button class="risk-tab active" id="rtab-calc" onclick="showRiskTab('calc')">📐 Calculator</button>
      <button class="risk-tab" id="rtab-quick" onclick="showRiskTab('quick')">⚡ Quick View</button>
      <button class="risk-tab" id="rtab-specs" onclick="showRiskTab('specs')">📋 Contract Specs</button>
      <button class="risk-tab" id="rtab-pnl"  onclick="showRiskTab('pnl')">📊 P&L Simulator</button>
    </div>

    <!-- ── TAB 1: MAIN CALCULATOR ── -->
    <div class="risk-tab-panel active" id="rtp-calc">

      <div style="text-align:center;padding:10px 0 16px;">
        <div class="section-tag"><img class="oa-logo-sm" src="data:image/png;base64," alt="OA">Obsession Arc Framework · Risk Calculator</div>
        <div style="font-size:11px;color:var(--text3);margin-top:4px;letter-spacing:0.5px;">Position Sizing & Risk Management · Futures Trading</div>
      </div>

      <!-- Instrument selector -->
      <div class="h1-card" style="margin-bottom:14px;">
        <div class="label" style="margin-bottom:10px;">Select Instrument</div>
        <div class="risk-instrument-grid" id="risk-inst-grid"></div>
        <div id="risk-inst-info" style="font-size:11px;color:var(--text2);line-height:1.6;margin-top:8px;padding:10px 12px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);display:none;"></div>
      </div>

      <!-- Inputs -->
      <div class="h1-card" style="margin-bottom:14px;">
        <div class="label" style="margin-bottom:12px;">Trade Parameters</div>
        <div class="risk-input-grid">
          <div class="risk-field">
            <label>Account Size ($)</label>
            <input type="number" id="r-account" placeholder="e.g. 50000" oninput="riskCalc()" value="25000">
          </div>
          <div class="risk-field">
            <label>Risk Per Trade (%)</label>
            <input type="number" id="r-riskpct" placeholder="e.g. 1" step="0.1" oninput="riskCalc()" value="1">
            <span class="field-hint">Recommended: 0.5% – 2% per trade</span>
          </div>
          <div class="risk-field">
            <label>Entry Price</label>
            <input type="number" id="r-entry" placeholder="e.g. 21500" oninput="riskCalc()">
          </div>
          <div class="risk-field">
            <label>Stop Loss Price</label>
            <input type="number" id="r-stop" placeholder="e.g. 21490" oninput="riskCalc()">
          </div>
          <div class="risk-field">
            <label>Target Price (optional)</label>
            <input type="number" id="r-target" placeholder="e.g. 21530" oninput="riskCalc()">
          </div>
          <div class="risk-field">
            <label>Direction</label>
            <select id="r-dir" onchange="riskCalc()">
              <option value="long">Long</option>
              <option value="short">Short</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Results -->
      <div id="risk-results-area" style="display:none;">

        <div class="risk-results-grid" id="risk-results-cards"></div>

        <div class="h1-card" style="margin-bottom:14px;">
          <div class="label" style="margin-bottom:10px;">Trade Breakdown</div>
          <div id="risk-breakdown"></div>
        </div>

        <div class="h1-card" style="margin-bottom:14px;">
          <div class="label" style="margin-bottom:6px;">Risk / Reward Ratio</div>
          <div id="risk-rr-area"></div>
        </div>

        <div id="risk-warnings"></div>
      </div>

      <div id="risk-placeholder" class="info-box" style="margin-top:0;">
        ← Select an instrument and fill in your trade parameters above to calculate position size and risk.
      </div>
    </div>

    <!-- ── TAB 2: QUICK VIEW ── -->
    <div class="risk-tab-panel" id="rtp-quick">

      <div style="text-align:center;padding:10px 0 16px;">
        <div class="section-tag"><img class="oa-logo-sm" src="data:image/png;base64," alt="OA">Obsession Arc Framework · Quick View</div>
        <div style="font-size:11px;color:var(--text3);margin-top:4px;letter-spacing:0.5px;">Instant Points → Dollar Reference Table</div>
      </div>

      <div class="h1-card" style="margin-bottom:14px;">
        <div class="label" style="margin-bottom:12px;">Quick P&L Lookup</div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
          <div class="risk-field" style="flex:1;min-width:120px;">
            <label>Instrument</label>
            <select id="qv-inst" onchange="qvBuild()">
              <option value="MNQ">MNQ — Micro NQ</option>
              <option value="NQ">NQ — E-mini NQ</option>
              <option value="MES">MES — Micro ES</option>
              <option value="ES">ES — E-mini S&P</option>
              <option value="YM">YM — Dow Jones</option>
              <option value="GC">GC — Gold</option>
              <option value="MGC">MGC — Micro Gold</option>
              <option value="6E">6E — Euro FX</option>
            </select>
          </div>
          <div class="risk-field" style="width:110px;">
            <label>Contracts</label>
            <input type="number" id="qv-contracts" value="1" min="1" max="50" oninput="qvBuild()">
          </div>
        </div>
      </div>

      <!-- instrument summary strip -->
      <div id="qv-inst-strip" style="margin-bottom:14px;"></div>

      <!-- the matrix table -->
      <div class="h1-card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px;">
          <div class="label" style="margin:0;">Points → Dollar Value</div>
          <div id="qv-headline" style="font-size:11px;color:var(--cyan);font-weight:600;"></div>
        </div>
        <div style="overflow-x:auto;">
          <table id="qv-table" style="width:100%;border-collapse:collapse;font-size:12px;"></table>
        </div>
        <div style="margin-top:14px;font-size:10px;color:var(--text3);line-height:1.7;" id="qv-footnote"></div>
      </div>

    </div>
    <div class="risk-tab-panel" id="rtp-specs">
      <div style="text-align:center;padding:10px 0 16px;">
        <div class="section-tag"><img class="oa-logo-sm" src="data:image/png;base64," alt="OA">Obsession Arc Framework · Contract Specs</div>
        <div style="font-size:11px;color:var(--text3);margin-top:4px;letter-spacing:0.5px;">Full Futures Contract Specifications Reference</div>
      </div>
      <div class="h1-card">
        <div class="label" style="margin-bottom:12px;">Contract Specifications — All Instruments</div>
        <div style="overflow-x:auto;">
          <table class="contract-spec-table" id="specs-table"></table>
        </div>
        <div class="info-box" style="margin-top:14px;">
          Tick values shown in USD. Margin requirements vary by broker and market conditions. Always confirm current margins with your broker before trading.
        </div>
      </div>
    </div>

    <!-- ── TAB 3: P&L SIMULATOR ── -->
    <div class="risk-tab-panel" id="rtp-pnl">
      <div style="text-align:center;padding:10px 0 16px;">
        <div class="section-tag"><img class="oa-logo-sm" src="data:image/png;base64," alt="OA">Obsession Arc Framework · P&L Simulator</div>
        <div style="font-size:11px;color:var(--text3);margin-top:4px;letter-spacing:0.5px;">Trade Profit & Loss Calculator · All Futures Instruments</div>
      </div>
      <div class="h1-card" style="margin-bottom:14px;">
        <div class="label" style="margin-bottom:12px;">Instrument & Position</div>
        <div class="risk-input-grid">
          <div class="risk-field">
            <label>Instrument</label>
            <select id="pnl-inst" onchange="pnlCalc()">
              <option value="">-- Select --</option>
            </select>
          </div>
          <div class="risk-field">
            <label>Number of Contracts</label>
            <input type="number" id="pnl-contracts" placeholder="e.g. 2" min="1" oninput="pnlCalc()" value="1">
          </div>
          <div class="risk-field">
            <label>Entry Price</label>
            <input type="number" id="pnl-entry" placeholder="Entry" oninput="pnlCalc()">
          </div>
          <div class="risk-field">
            <label>Exit Price</label>
            <input type="number" id="pnl-exit" placeholder="Exit" oninput="pnlCalc()">
          </div>
          <div class="risk-field">
            <label>Direction</label>
            <select id="pnl-dir" onchange="pnlCalc()">
              <option value="long">Long</option>
              <option value="short">Short</option>
            </select>
          </div>
          <div class="risk-field">
            <label>Commission / Side ($)</label>
            <input type="number" id="pnl-comm" placeholder="e.g. 2.50" step="0.01" value="2.25" oninput="pnlCalc()">
          </div>
        </div>
      </div>

      <div id="pnl-results" style="display:none;">
        <div class="risk-results-grid" id="pnl-cards"></div>
        <div class="h1-card" style="margin-bottom:14px;">
          <div class="label" style="margin-bottom:10px;">P&L Breakdown</div>
          <div id="pnl-breakdown"></div>
        </div>
        <!-- Points table -->
        <div class="h1-card">
          <div class="label" style="margin-bottom:10px;">Point Value Reference (1 Contract)</div>
          <div id="pnl-point-table"></div>
        </div>
      </div>
      <div id="pnl-placeholder" class="info-box">Select instrument and enter entry/exit prices to simulate P&L.</div>
    </div>

  </div>
</div><!-- /view-risk -->


<!-- ══════════════════════════════════════
     VIEW 4: SDRANGE+ FRAMEWORK
══════════════════════════════════════ -->
<div class="app-view" id="view-sdrange">
  <div class="container" style="max-width:900px;">

    <div style="text-align:center;padding:18px 0 6px;">
      <div class="section-tag">SDRange+ [JJumbo] · Framework Reference</div>
      <div style="font-size:11px;color:var(--text3);margin-top:4px;letter-spacing:0.5px;">Overnight Session Range · Level Projections · Session Liquidity</div>
    </div>

    <!-- ── Intro Card ── -->
    <div class="h1-card" style="margin-bottom:14px;padding:20px;">
      <div style="display:flex;align-items:flex-start;gap:14px;">
        <div style="flex:1;">
          <div class="label" style="margin-bottom:6px;">Overview</div>
          <div style="font-size:12px;color:var(--text2);line-height:1.8;">
            A versatile and highly customizable tool crafted for traders who rely on <span style="color:var(--cyan);">precise price levels</span> and <span style="color:var(--cyan);">time-based analysis</span>, with a special focus on the Overnight Session (ONS) range. Defaults to the critical <span style="color:var(--amber);">6:00 AM – 9:00 AM ET</span> window — a period often pivotal for setting the day's momentum before RTH commences.
          </div>
        </div>
      </div>
    </div>

    <!-- ── Key Features Grid ── -->
    <div class="h1-grid-2" style="margin-bottom:14px;">

      <!-- Range Dynamics -->
      <div class="h1-card" style="padding:18px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
          <div class="badge badge-cyan">Range Dynamics</div>
        </div>
        <div style="font-size:12px;color:var(--text2);line-height:1.75;margin-bottom:10px;">
          Time-based ranges (user-defined) with projections marking <strong style="color:var(--text1);">exhaustion points</strong> and profit-taking areas of the chosen range.
        </div>
        <div style="background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:10px;margin-bottom:8px;">
          <div class="label" style="margin-bottom:4px;">x0.5 Projection</div>
          <div style="font-size:11px;color:var(--red);">Exhaustion / range extension target</div>
        </div>
        <div style="background:var(--cyan-dim);border:1px solid var(--cyan-border);border-radius:var(--radius);padding:10px;">
          <div class="label" style="margin-bottom:4px;">x1.33–1.66 Projections</div>
          <div style="font-size:11px;color:var(--cyan);">Profit-taking & position-closing zone · <strong>Rule of Thirds</strong></div>
        </div>
      </div>

      <!-- Sessions Liquidity -->
      <div class="h1-card" style="padding:18px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
          <div class="badge badge-green">Sessions Liquidity</div>
        </div>
        <div style="font-size:12px;color:var(--text2);line-height:1.75;margin-bottom:10px;">
          Pivot sessions automatically mark the <strong style="color:var(--text1);">swing high & low</strong> of user-defined sessions (Asia, London) — where stop hunts form, creating potential reversal or take-profit levels.
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
          <div class="h1-stat" style="padding:8px;">
            <div class="label">Asia Session</div>
            <div style="font-size:11px;color:var(--amber);font-weight:700;">High / Low</div>
          </div>
          <div class="h1-stat" style="padding:8px;">
            <div class="label">London Session</div>
            <div style="font-size:11px;color:var(--blue);font-weight:700;">High / Low</div>
          </div>
        </div>
        <div style="margin-top:8px;font-size:11px;color:var(--text3);line-height:1.6;">Pivot line <span style="color:var(--red);">deletes when tagged</span> — a triangle plots to alert you it has been tagged.</div>
      </div>
    </div>

    <!-- ── Projection Levels Reference ── -->
    <div class="h1-card" style="margin-bottom:14px;padding:18px;">
      <div class="label" style="margin-bottom:12px;">Range Projection Levels · Reference</div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:14px;">
        <div class="h1-stat" style="border-color:rgba(239,68,68,0.35);">
          <div class="label">x0.5</div>
          <div style="font-size:13px;font-weight:700;color:var(--red);">Exhaustion</div>
          <div style="font-size:10px;color:var(--text3);margin-top:3px;">Half-range ext.</div>
        </div>
        <div class="h1-stat">
          <div class="label">Range Open</div>
          <div style="font-size:13px;font-weight:700;color:var(--green);">Level of Action</div>
          <div style="font-size:10px;color:var(--text3);margin-top:3px;">Reactions → projections</div>
        </div>
        <div class="h1-stat" style="border-color:rgba(34,211,238,0.35);">
          <div class="label">x1.33</div>
          <div style="font-size:13px;font-weight:700;color:var(--cyan);">Retracement Zone</div>
          <div style="font-size:10px;color:var(--text3);margin-top:3px;">Rule of Thirds</div>
        </div>
        <div class="h1-stat" style="border-color:rgba(34,211,238,0.5);">
          <div class="label">x1.66</div>
          <div style="font-size:13px;font-weight:700;color:var(--cyan);">Reversal Area</div>
          <div style="font-size:10px;color:var(--text3);margin-top:3px;">Profit-closing zone</div>
        </div>
      </div>
      <div style="background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:12px;">
        <div style="font-size:11px;color:var(--text2);line-height:1.8;">
          The <span style="color:var(--cyan);">1.33–1.66 projection area</span> derives from a mathematical calculation called the <strong style="color:var(--text1);">"Rule of Thirds"</strong> — where algorithms in funds set logical profit-taking and position closing, making price behave in the sense of retracing or reverting from said levels.
        </div>
      </div>
    </div>

    <!-- ── Two Trade Scenarios ── -->
    <div class="h1-card" style="margin-bottom:14px;padding:18px;">
      <div class="label" style="margin-bottom:14px;">Two Trade Scenarios · How to Use the Framework</div>
      <div class="h1-grid-2">

        <!-- Reversal Trade -->
        <div style="background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:14px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
            <div class="badge badge-red">Reversal / Fade</div>
          </div>
          <div style="font-size:12px;color:var(--text2);line-height:1.75;margin-bottom:10px;">
            Fade the range breakout and capitalize on <strong style="color:var(--text1);">breakout failure</strong>, targeting opposing levels of the breakout direction.
          </div>
          <div style="font-size:11px;color:var(--text3);line-height:1.6;">
            → Use the <span style="color:var(--cyan);">1.33–1.66 zone</span> to anticipate the reaction — whether a retracement or full reversal, it provides the move needed to capitalize.
          </div>
        </div>

        <!-- Breakout Trade -->
        <div style="background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:14px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
            <div class="badge badge-green">Breakout / Continuation</div>
          </div>
          <div style="font-size:12px;color:var(--text2);line-height:1.75;margin-bottom:10px;">
            Anticipate early breakouts using <strong style="color:var(--text1);">inner-range levels</strong> — Range Open or midpoint — as guidance for positioning.
          </div>
          <div style="font-size:11px;color:var(--text3);line-height:1.6;">
            → <span style="color:var(--green);">Range Open</span> becomes the target after a range break when remaining un-tapped. Statistically, retracement to range open post-sweep has a <span style="color:var(--green);">very high hit %.</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Range Open Rule ── -->
    <div class="h1-card" style="margin-bottom:14px;padding:18px;">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
        <div class="badge badge-amber">Range Open Rule</div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div>
          <div style="font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--text3);margin-bottom:6px;">During the Range</div>
          <div style="font-size:12px;color:var(--text2);line-height:1.75;">
            Range open often plays as a <strong style="color:var(--amber);">level of action</strong> — generating reactions that then distribute to projections.
          </div>
        </div>
        <div>
          <div style="font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--text3);margin-bottom:6px;">After Range Break</div>
          <div style="font-size:12px;color:var(--text2);line-height:1.75;">
            Inversely, the range open becomes our <strong style="color:var(--green);">target</strong> after the range break when remaining un-tapped.
          </div>
        </div>
      </div>
    </div>

    <!-- ── ONS Default Window ── -->
    <div class="h1-card" style="padding:18px;">
      <div class="label" style="margin-bottom:12px;">Default Session Window · Overnight Session (ONS)</div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px;">
        <div class="h1-stat">
          <div class="label">Window Start</div>
          <div style="font-size:16px;font-weight:700;color:var(--cyan);">6:00 AM</div>
          <div style="font-size:10px;color:var(--text3);">Eastern Time</div>
        </div>
        <div class="h1-stat">
          <div class="label">Window End</div>
          <div style="font-size:16px;font-weight:700;color:var(--cyan);">9:00 AM</div>
          <div style="font-size:10px;color:var(--text3);">Eastern Time</div>
        </div>
        <div class="h1-stat">
          <div class="label">Duration</div>
          <div style="font-size:16px;font-weight:700;color:var(--amber);">3 Hours</div>
          <div style="font-size:10px;color:var(--text3);">Pre-RTH key zone</div>
        </div>
      </div>
      <div style="background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:10px;">
        <div style="font-size:11px;color:var(--text3);line-height:1.7;">
          <span style="color:var(--green);">✦</span> The tool supports fully custom session windows — adapt to any preferred time period for various trading styles and market conditions beyond the standard overnight session.
          <br><span style="color:var(--green);">✦</span> Statistics for <span style="color:var(--cyan);">x0.5</span> and <span style="color:var(--cyan);">1.33–1.66</span> are calculated externally for the 6am–9am ET range. The projections function as points of interest to frame trades and position on the right side of the market.
        </div>
      </div>
    </div>

  </div>
</div><!-- /view-sdrange -->


<script>
/* ═══════════════════════════════
   DATA
═══════════════════════════════ */
const HOURS = [
  {t:0,  tw:"01:00", wr:78.7, avg:9,  bull:80, bear:77, top:true},
